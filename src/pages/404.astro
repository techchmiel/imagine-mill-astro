---
import { SITE_TITLE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title={`Page not found — ${SITE_TITLE}`}
	description="That page doesn't exist — but the mill has plenty that does."
>
	<div class="im-container wrap">
		<span class="im-eyebrow">404 · Signal lost</span>
		<h1>This node isn't connected</h1>
		<p>
			The page you're after moved, retired, or never existed. It happens to the best of tenants.
		</p>
		<div class="ctas">
			<a class="im-btn im-btn--primary im-btn--md" href="/">Back to home</a>
			<button class="im-btn im-btn--secondary im-btn--md" type="button" data-search-open>
				Search the site
			</button>
		</div>
	</div>
</BaseLayout>
<style>
	.wrap {
		padding: var(--space-24) var(--gutter);
		text-align: center;
	}
	h1 {
		margin: var(--space-3) 0;
	}
	p {
		color: var(--text-muted);
		max-width: 44ch;
		margin: 0 auto var(--space-6);
	}
	.ctas {
		display: flex;
		gap: var(--space-3);
		justify-content: center;
		flex-wrap: wrap;
	}
</style>
