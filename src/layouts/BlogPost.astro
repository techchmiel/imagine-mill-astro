---
import { Image } from 'astro:assets';
import { type CollectionEntry, getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import GradientArt from '../components/GradientArt.astro';
import PostCard from '../components/PostCard.astro';
import TagChip from '../components/TagChip.astro';
import { AUDIENCES, CATEGORIES, platformName, readingTime } from '../consts';
import BaseLayout from './BaseLayout.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	heroStyle,
	category,
	platforms,
	tags,
	audience,
} = post.data;
const cat = CATEGORIES[category];
const minutes = readingTime(post.body);

// Related: most shared platforms/tags, newest first as tiebreak.
const all = await getCollection('blog', ({ id, data }) => id !== post.id && !data.draft);
const related = all
	.map((p) => ({
		p,
		s:
			p.data.platforms.filter((x) => platforms.includes(x)).length * 2 +
			p.data.tags.filter((x) => tags.includes(x)).length +
			(p.data.category === category ? 1 : 0),
	}))
	.sort((a, b) => b.s - a.s || b.p.data.pubDate.valueOf() - a.p.data.pubDate.valueOf())
	.slice(0, 3)
	.map(({ p }) => p);
---

<BaseLayout title={title} description={description} image={heroImage}>
	<article>
		<div class="article-hero">
			<div class="im-container im-container--md">
				<div class="eyebrow-row">
					<a class="im-eyebrow" href={`/categories/${category}/`}>{cat?.name ?? category}</a>
					<span class="im-node" aria-hidden="true"></span>
					<span class="eyebrow-platforms">
						{
							platforms.map((p, i) => (
								<>
									{i > 0 && <span class="sep">·</span>}
									<a class="im-eyebrow platform" href={`/platforms/${p}/`}>
										{platformName(p)}
									</a>
								</>
							))
						}
					</span>
				</div>
				<h1>{title}</h1>
				<p class="lede">{description}</p>
				<div class="meta-row">
					<FormattedDate date={pubDate} />
					<span class="sep">·</span>
					<span>{minutes} min read</span>
					<span class="sep">·</span>
					<span>For {AUDIENCES[audience]?.toLowerCase() ?? audience}</span>
					{
						updatedDate && (
							<>
								<span class="sep">·</span>
								<span class="updated">
									Updated <FormattedDate date={updatedDate} />
								</span>
							</>
						)
					}
				</div>
			</div>
		</div>
		<div class="im-container im-container--md">
			<div class="hero-media">
				{
					heroImage ? (
						<Image width={1020} height={510} src={heroImage} alt="" />
					) : (
						<GradientArt seed={post.id} style={heroStyle} />
					)
				}
			</div>
			<div class="prose">
				<slot />
			</div>
			<footer class="article-footer">
				<hr class="im-signal-rule" />
				<div class="tags">
					{tags.map((t) => <TagChip href={`/tags/${t}/`}>{t}</TagChip>)}
				</div>
				<a class="back" href="/articles/">← All articles</a>
			</footer>
		</div>
		{
			related.length > 0 && (
				<aside class="related">
					<div class="im-container">
						<h2>Keep reading</h2>
						<div class="grid">
							{related.map((p) => (
								<PostCard post={p} />
							))}
						</div>
					</div>
				</aside>
			)
		}
	</article>
</BaseLayout>
<style>
	.article-hero {
		background: var(--gradient-screen-soft);
		border-bottom: 1px solid var(--blue-100);
		padding: var(--space-12) 0 var(--space-10);
	}
	.eyebrow-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 10px;
		margin-bottom: var(--space-4);
	}
	.eyebrow-row a {
		text-decoration: none;
	}
	.eyebrow-row a:hover {
		text-decoration: underline;
	}
	.eyebrow-row .im-eyebrow:first-child {
		color: var(--red-500);
	}
	.im-node {
		color: var(--green-500);
		width: 9px;
		height: 9px;
	}
	.eyebrow-platforms {
		display: inline-flex;
		align-items: center;
		gap: 8px;
	}
	h1 {
		font-size: clamp(30px, 5vw, var(--fs-display-m));
		line-height: var(--lh-heading);
		margin: 0 0 var(--space-4);
		max-width: 24ch;
	}
	.lede {
		font-size: var(--fs-body-lg);
		color: var(--text-body);
		max-width: 56ch;
		margin: 0 0 var(--space-5);
	}
	.meta-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 8px;
		font-size: var(--fs-body-sm);
		color: var(--text-muted);
	}
	.sep {
		color: var(--gray-300);
	}
	.updated {
		font-style: italic;
	}
	.hero-media {
		aspect-ratio: 2 / 1;
		border-radius: var(--radius-xl);
		overflow: hidden;
		box-shadow: var(--shadow-lg);
		margin: var(--space-8) 0 0;
	}
	.hero-media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.prose {
		margin-top: var(--space-10);
	}
	.article-footer {
		margin-top: var(--space-12);
	}
	.article-footer .im-signal-rule {
		width: 64px;
		margin: 0 0 var(--space-6);
	}
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-bottom: var(--space-6);
	}
	.back {
		font-family: var(--font-display);
		font-weight: var(--fw-semibold);
		font-size: var(--fs-body-sm);
		letter-spacing: var(--ls-wide);
	}
	.related {
		background: var(--gray-050);
		border-top: 1px solid var(--border-subtle);
		margin-top: var(--space-16);
		padding: var(--space-16) 0 var(--space-4);
	}
	.related h2 {
		margin-bottom: var(--space-6);
	}
	.related .grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-6);
	}
	@media (max-width: 900px) {
		.related .grid {
			grid-template-columns: 1fr;
		}
	}
</style>
