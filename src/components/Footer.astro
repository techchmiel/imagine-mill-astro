---
import { CATEGORIES, PLATFORMS, SITE_TAGLINE } from '../consts';

const today = new Date();
---

<footer class="im-circuit-bg">
	<div class="im-container inner">
		<div class="col about">
			<img src="/brand/imaginemill-icon.png" alt="" width="44" height="44" />
			<p class="tagline">{SITE_TAGLINE}</p>
			<p class="blurb">
				Guides to Microsoft 365, cloud, and AI for the people who keep modern workplaces running.
				Written to be understood.
			</p>
			<hr class="im-signal-rule" />
		</div>
		<div class="col">
			<p class="col-title">Platforms</p>
			<ul>
				{
					Object.entries(PLATFORMS).map(([slug, p]) => (
						<li>
							<a href={`/platforms/${slug}/`}>{p.name}</a>
						</li>
					))
				}
			</ul>
		</div>
		<div class="col">
			<p class="col-title">Read by type</p>
			<ul>
				{
					Object.entries(CATEGORIES).map(([slug, c]) => (
						<li>
							<a href={`/categories/${slug}/`}>{c.name}</a>
						</li>
					))
				}
			</ul>
		</div>
		<div class="col">
			<p class="col-title">ImagineMill</p>
			<ul>
				<li><a href="/articles/">All articles</a></li>
				<li><a href="/topics/">Browse topics</a></li>
				<li><a href="/about/">About</a></li>
				<li><a href="/rss.xml">RSS feed</a></li>
				<li><a href="/unsubscribe/">Unsubscribe</a></li>
			</ul>
		</div>
	</div>
	<div class="im-container legal">
		<p>&copy; {today.getFullYear()} PortalSpark. ImagineMill is a free learning resource — {SITE_TAGLINE.toLowerCase()}.</p>
	</div>
</footer>
<style>
	footer {
		margin-top: var(--space-24);
		color: var(--text-on-navy);
	}
	.inner {
		display: grid;
		grid-template-columns: 1.6fr 1fr 1fr 1fr;
		gap: var(--space-10);
		padding-top: var(--space-16);
		padding-bottom: var(--space-10);
	}
	.about img {
		display: block;
		margin-bottom: var(--space-4);
	}
	.tagline {
		font-family: var(--font-display);
		font-weight: var(--fw-semibold);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-wider);
		text-transform: uppercase;
		color: var(--blue-300);
		margin: 0 0 var(--space-2);
	}
	.blurb {
		color: var(--text-on-navy-muted);
		font-size: var(--fs-body-sm);
		max-width: 34ch;
		margin: 0 0 var(--space-5);
	}
	.im-signal-rule {
		width: 56px;
		margin: 0;
	}
	.col-title {
		font-family: var(--font-display);
		font-weight: var(--fw-semibold);
		font-size: var(--fs-caption);
		letter-spacing: var(--ls-wider);
		text-transform: uppercase;
		color: #fff;
		margin: 6px 0 var(--space-3);
	}
	ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	li {
		margin-bottom: 8px;
	}
	.col a {
		color: var(--text-on-navy-muted);
		font-size: var(--fs-body-sm);
		text-decoration: none;
		transition: color var(--dur-base) var(--ease-standard);
	}
	.col a:hover {
		color: var(--blue-300);
	}
	.legal {
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		padding-top: var(--space-5);
		padding-bottom: var(--space-8);
	}
	.legal p {
		margin: 0;
		font-size: var(--fs-caption);
		color: var(--text-on-navy-muted);
	}
	@media (max-width: 900px) {
		.inner {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-8);
		}
	}
	@media (max-width: 560px) {
		.inner {
			grid-template-columns: 1fr;
		}
	}
</style>
