---
/**
 * Site-wide search: a command-palette style dialog fed by /search.json
 * (built at compile time from the blog collection). Opens from any
 * [data-search-open] button, or with ⌘K / Ctrl+K, or "/".
 */
---

<dialog class="search-dialog" data-search-dialog>
	<div class="box">
		<div class="input-row">
			<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="11" cy="11" r="8"></circle>
				<path d="m21 21-4.3-4.3"></path>
			</svg>
			<input
				type="search"
				placeholder="Search articles — try “copilot”, “sharing”, “licensing”…"
				aria-label="Search articles"
				autocomplete="off"
				data-search-input
			/>
			<button class="close" type="button" data-search-close aria-label="Close search">esc</button>
		</div>
		<div class="results" data-search-results role="listbox" aria-label="Search results"></div>
		<div class="hint" data-search-hint>
			Type to search titles, topics, and article text. <kbd>↑</kbd><kbd>↓</kbd> to move, <kbd>↵</kbd> to open.
		</div>
	</div>
</dialog>

<script>
	type Doc = {
		url: string;
		title: string;
		description: string;
		category: string;
		platforms: string[];
		tags: string[];
		body: string;
	};

	const dialog = document.querySelector<HTMLDialogElement>('[data-search-dialog]');
	const input = document.querySelector<HTMLInputElement>('[data-search-input]');
	const resultsEl = document.querySelector<HTMLElement>('[data-search-results]');
	const hintEl = document.querySelector<HTMLElement>('[data-search-hint]');

	let docs: Doc[] | null = null;
	let active = -1;

	async function loadIndex(): Promise<Doc[]> {
		if (!docs) {
			const res = await fetch('/search.json');
			docs = (await res.json()) as Doc[];
		}
		return docs;
	}

	function score(doc: Doc, terms: string[]): number {
		let total = 0;
		const title = doc.title.toLowerCase();
		const desc = doc.description.toLowerCase();
		const meta = [doc.category, ...doc.platforms, ...doc.tags].join(' ').toLowerCase();
		const body = doc.body.toLowerCase();
		for (const t of terms) {
			let s = 0;
			if (title.includes(t)) s += 8;
			if (meta.includes(t)) s += 5;
			if (desc.includes(t)) s += 3;
			if (body.includes(t)) s += 1;
			if (s === 0) return 0; // every term must match somewhere
			total += s;
		}
		return total;
	}

	function excerpt(doc: Doc, terms: string[]): string {
		const body = doc.body;
		const lower = body.toLowerCase();
		for (const t of terms) {
			const i = lower.indexOf(t);
			if (i >= 0) {
				const start = Math.max(0, i - 60);
				const end = Math.min(body.length, i + 100);
				return (start > 0 ? '…' : '') + body.slice(start, end).trim() + (end < body.length ? '…' : '');
			}
		}
		return doc.description;
	}

	function highlight(text: string, terms: string[]): string {
		let safe = text
			.replace(/&/g, '&amp;')
			.replace(/</g, '&lt;')
			.replace(/>/g, '&gt;');
		for (const t of terms) {
			if (!t) continue;
			const esc = t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
			safe = safe.replace(new RegExp(`(${esc})`, 'gi'), '<mark>$1</mark>');
		}
		return safe;
	}

	function render(list: { doc: Doc }[], terms: string[]) {
		if (!resultsEl || !hintEl) return;
		active = -1;
		if (!terms.length) {
			resultsEl.innerHTML = '';
			hintEl.hidden = false;
			return;
		}
		hintEl.hidden = true;
		if (!list.length) {
			resultsEl.innerHTML =
				'<p class="empty">Nothing yet — try a product name (Teams, Copilot, Azure) or a task (“share a file”, “licensing”).</p>';
			return;
		}
		resultsEl.innerHTML = list
			.map(
				({ doc }, i) => `
				<a class="result" role="option" data-index="${i}" href="${doc.url}">
					<span class="result-top">
						<span class="result-title">${highlight(doc.title, terms)}</span>
						<span class="result-cat">${doc.category}</span>
					</span>
					<span class="result-excerpt">${highlight(excerpt(doc, terms), terms)}</span>
					<span class="result-meta">${doc.platforms.join(' · ')}</span>
				</a>`,
			)
			.join('');
	}

	async function update() {
		if (!input) return;
		const terms = input.value.toLowerCase().split(/\s+/).filter(Boolean);
		const index = await loadIndex();
		const matches = index
			.map((doc) => ({ doc, s: terms.length ? score(doc, terms) : 0 }))
			.filter((r) => r.s > 0)
			.sort((a, b) => b.s - a.s)
			.slice(0, 8);
		render(matches, terms);
	}

	function open() {
		if (!dialog) return;
		dialog.showModal();
		input?.focus();
		loadIndex();
	}
	function close() {
		dialog?.close();
	}

	document.querySelectorAll('[data-search-open]').forEach((btn) => {
		btn.addEventListener('click', open);
	});
	document.querySelector('[data-search-close]')?.addEventListener('click', close);
	dialog?.addEventListener('click', (e) => {
		if (e.target === dialog) close(); // backdrop click
	});

	document.addEventListener('keydown', (e) => {
		if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
			e.preventDefault();
			dialog?.open ? close() : open();
		}
		if (e.key === '/' && !dialog?.open) {
			const t = e.target as HTMLElement;
			if (t.tagName !== 'INPUT' && t.tagName !== 'TEXTAREA' && !t.isContentEditable) {
				e.preventDefault();
				open();
			}
		}
	});

	function setActive(next: number) {
		if (!resultsEl) return;
		const items = resultsEl.querySelectorAll<HTMLElement>('.result');
		if (!items.length) return;
		active = (next + items.length) % items.length;
		items.forEach((el, i) => el.classList.toggle('active', i === active));
		items[active].scrollIntoView({ block: 'nearest' });
	}

	input?.addEventListener('input', update);
	input?.addEventListener('keydown', (e) => {
		if (e.key === 'ArrowDown') {
			e.preventDefault();
			setActive(active + 1);
		} else if (e.key === 'ArrowUp') {
			e.preventDefault();
			setActive(active - 1);
		} else if (e.key === 'Enter') {
			const items = resultsEl?.querySelectorAll<HTMLAnchorElement>('.result');
			const target = items && items[active >= 0 ? active : 0];
			if (target) {
				e.preventDefault();
				window.location.href = target.href;
			}
		}
	});
</script>

<style>
	.search-dialog {
		width: min(620px, calc(100vw - 32px));
		border: none;
		border-radius: var(--radius-xl);
		padding: 0;
		margin-top: 12vh;
		background: transparent;
		overflow: visible;
	}
	.search-dialog::backdrop {
		background: rgba(16, 24, 64, 0.45);
		backdrop-filter: blur(4px);
	}
	.box {
		background: var(--surface-card);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-xl);
		overflow: hidden;
	}
	.input-row {
		display: flex;
		align-items: center;
		gap: 10px;
		padding: 14px 16px;
		border-bottom: 1px solid var(--border-subtle);
		color: var(--blue-600);
	}
	input {
		flex: 1;
		border: none;
		outline: none;
		font-family: var(--font-body);
		font-size: var(--fs-body-lg);
		color: var(--navy-900);
		background: transparent;
	}
	input::placeholder {
		color: var(--text-faint);
	}
	input:focus-visible {
		box-shadow: none;
	}
	.close {
		font-family: var(--font-mono);
		font-size: var(--fs-micro);
		color: var(--text-faint);
		background: var(--gray-050);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-xs);
		padding: 3px 7px;
		cursor: pointer;
	}
	.results {
		max-height: 46vh;
		overflow-y: auto;
	}
	.results :global(.result) {
		display: flex;
		flex-direction: column;
		gap: 3px;
		padding: 12px 16px;
		text-decoration: none;
		border-bottom: 1px solid var(--gray-100);
		transition: background-color var(--dur-fast) var(--ease-standard);
	}
	.results :global(.result:hover),
	.results :global(.result.active) {
		background: var(--blue-050);
	}
	.results :global(.result-top) {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 12px;
	}
	.results :global(.result-title) {
		font-family: var(--font-display);
		font-weight: var(--fw-bold);
		color: var(--text-strong);
		font-size: var(--fs-body);
	}
	.results :global(.result-cat) {
		font-family: var(--font-display);
		font-size: var(--fs-micro);
		letter-spacing: var(--ls-wide);
		text-transform: uppercase;
		color: var(--blue-700);
		flex: none;
	}
	.results :global(.result-excerpt) {
		font-size: var(--fs-body-sm);
		color: var(--text-muted);
	}
	.results :global(.result-meta) {
		font-size: var(--fs-caption);
		color: var(--text-faint);
	}
	.results :global(mark) {
		background: var(--blue-100);
		color: var(--navy-800);
		border-radius: 2px;
		padding: 0 1px;
	}
	.results :global(.empty) {
		padding: 20px 16px;
		margin: 0;
		color: var(--text-muted);
		font-size: var(--fs-body-sm);
	}
	.hint {
		padding: 10px 16px;
		font-size: var(--fs-caption);
		color: var(--text-faint);
		border-top: 1px solid var(--gray-100);
	}
	.hint kbd {
		font-family: var(--font-mono);
		font-size: var(--fs-micro);
		background: var(--gray-050);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-xs);
		padding: 1px 4px;
		margin: 0 2px;
	}
</style>
